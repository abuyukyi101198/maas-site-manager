{
  "layers": [
    {
      "id": "background",
      "type": "background",
      "layout": { "visibility": "visible" },
      "paint": { "background-color": "rgba(51, 51, 51, 1)" }
    },
    {
      "id": "land",
      "type": "fill",
      "source": "naturalearth",
      "source-layer": "land",
      "layout": { "visibility": "visible" },
      "paint": { "fill-color": "rgba(243, 243, 243, 1)" }
    },
    {
      "id": "water_inland",
      "type": "fill",
      "source": "naturalearth",
      "source-layer": "lake",
      "layout": { "visibility": "visible" },
      "paint": { "fill-color": "rgba(215, 223, 232, 1)" }
    },
    {
      "id": "river",
      "type": "line",
      "source": "naturalearth",
      "source-layer": "river",
      "layout": { "visibility": "visible" },
      "paint": {
        "line-color": "rgba(215, 223, 232, 1)",
        "line-width": {
          "base": 1.5,
          "stops": [
            [0, 1.5],
            [12, 15]
          ]
        }
      }
    },
    {
      "id": "transportation",
      "type": "line",
      "metadata": {},
      "source": "naturalearth",
      "source-layer": "road",
      "minzoom": 5,
      "filter": ["all", ["in", "type", "Secondary Highway", "Major Highway", "Road"]],
      "layout": { "visibility": "visible" },
      "paint": {
        "line-width": {
          "stops": [
            [12, 0.5],
            [16, 1],
            [17, 3]
          ]
        },
        "line-color": {
          "stops": [
            [12, "rgba(212, 209, 209, 1)"],
            [16, "rgba(8, 8, 8, 1)"]
          ]
        }
      }
    },
    {
      "id": "city",
      "type": "symbol",
      "source": "naturalearth",
      "source-layer": "city",
      "minzoom": 5,
      "maxzoom": 16,
      "layout": {
        "text-field": ["get", "NAME"],
        "text-font": ["Noto Sans Regular"],
        "text-max-width": 10,
        "text-size": {
          "stops": [
            [3, 16],
            [8, 16]
          ]
        },
        "visibility": "visible"
      },
      "paint": {
        "text-color": "hsl(0, 0%, 0%)",
        "text-halo-color": "hsla(0, 0%, 100%, 0.75)",
        "text-halo-blur": 0,
        "text-halo-width": 2
      }
    },
    {
      "id": "state",
      "type": "line",
      "source": "naturalearth",
      "source-layer": "state",
      "minzoom": 4,
      "layout": {
        "line-cap": "round",
        "line-join": "round",
        "visibility": "visible"
      },
      "paint": {
        "line-color": "rgba(72, 70, 70, 1)",
        "line-width": {
          "base": 1.3,
          "stops": [
            [3, 1.5],
            [22, 15]
          ]
        },
        "line-blur": 0.4,
        "line-dasharray": [0.5, 2],
        "line-opacity": 1
      }
    },
    {
      "id": "border",
      "type": "line",
      "source": "naturalearth",
      "source-layer": "border",
      "layout": {
        "line-cap": "round",
        "line-join": "round",
        "visibility": "visible"
      },
      "paint": {
        "line-color": "rgba(0, 0, 0, 1)",
        "line-width": {
          "base": 1.1,
          "stops": [
            [3, 2],
            [22, 20]
          ]
        },
        "line-blur": {
          "base": 1,
          "stops": [
            [0, 0.4],
            [22, 4]
          ]
        },
        "line-opacity": 1
      }
    },
    {
      "id": "road",
      "type": "symbol",
      "source": "naturalearth",
      "source-layer": "road",
      "minzoom": 12.2,
      "layout": {
        "text-size": {
          "base": 1,
          "stops": [
            [13, 12],
            [14, 13]
          ]
        },
        "symbol-placement": "line-center",
        "text-font": ["Noto Sans Regular"],
        "text-field": ["get", "label"],
        "text-rotation-alignment": "map",
        "visibility": "visible"
      },
      "paint": {
        "text-halo-blur": 0.5,
        "text-color": "rgba(0, 0, 0, 1)",
        "text-halo-width": 1,
        "text-halo-color": "rgba(255, 255, 255, 1)"
      }
    },
    {
      "id": "country",
      "type": "symbol",
      "source": "naturalearth",
      "source-layer": "country",
      "layout": {
        "visibility": "visible",
        "text-field": ["get", "sr_subunit"],
        "symbol-avoid-edges": true,
        "text-font": ["Noto Sans Regular"],
        "text-size": {
          "stops": [
            [3, 14],
            [8, 16]
          ]
        }
      },
      "paint": { "text-halo-color": "#fff", "text-halo-width": 1.5 },
      "filter": ["all", ["==", "scalerank", 0]]
    }
  ]
}
